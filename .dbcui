<?php
 function dbConnect($connection=null) { static $db; if (is_null($db)) { if (is_null($connection)) { throw new \Exception("db is not connected"); } $db = new PDO( 'mysql:host='.$connection['host'].';port='.$connection['port'].';dbname='.$connection['dbname'], $connection['user'], $connection['password'], [PDO::ATTR_PERSISTENT => false, PDO::MYSQL_ATTR_INIT_COMMAND => 'SET NAMES utf8'] ); } return $db; } function execSQL($sql) { $db = dbConnect(); $stmt = $db->prepare($sql); if (!$stmt) { $error = $db->errorInfo(); $errorMessage = implode(',', $error); throw new \Exception($errorMessage); } $success = $stmt->execute(); if (!$success) { $error = "sql execute error"; throw new Exception($error); } return $stmt; } function select($sql) { $stmt = execSQL($sql); $p9 = $stmt->fetchAll(); $p23 = []; $rowIndex = -1; foreach ($p9 as $row) { $rowIndex++; $p23[$rowIndex] = []; foreach ($row as $colName => $colValue) { if (is_numeric($colName)) { continue; } $p23[$rowIndex][$colName] = $colValue; } } return $p23; } function transactionStart() { $db = dbConnect(); $db->beginTransaction(); } function commit() { $db = dbConnect(); $db->commit(); } function rollback() { $db = dbConnect(); $db->rollBack(); } function getTableColumns($table) { $columns = []; $sql = "SHOW COLUMNS FROM {$table} FROM ". config('MYSQL_DB_NAME', 'required'); $selected = select($sql); foreach ($selected as $row) { $columns[] = $row['Field']; } return $columns; } class SQLite { public static $db = null; static public function open($p17Path) { self::$db = new PDO("sqlite:" . $p17Path); } static public function close() { self::$db = null; } static public function createTable($sql) { if (is_null(self::$db)) { self::open(); } $p23 = self::$db->exec($sql); if (!$p23) { $error = self::$db->errorInfo(); $errorMessage = implode(',', $error); throw new \Exception($errorMessage); } } static public function select($sql) { return self::execSelect($sql); } static public function escape($value) { return str_replace(["'"], ["''"], $value); } static public function insert($table, $data) { $sql = 'insert into '.$table.' (@@cols@@) values (@@values@@);'; $cols = ''; $values = ''; foreach ($data as $key => $value) { if ($cols != '') { $cols .= ', '; $values .= ', '; } $cols .= $key; $values .= "'" . self::escape($value) . "'"; } $sql = str_replace(['@@cols@@', '@@values@@'], [$cols, $values], $sql); self::execSQL($sql); return self::$db->lastInsertId(); } static public function update($table, $data, $where) { $sql = 'update '.$table.' set @@data@@ where ' . $where; $dataStr = ''; foreach ($data as $key => $value) { if ($dataStr != '') { $dataStr .= ', '; } $dataStr .= $key . "= '" . self::escape($value) . "'"; } $sql = str_replace('@@data@@', $dataStr, $sql); return self::execSQL($sql); } static public function selectRaw($sql, $params = []) { foreach ($params as $key => $value) { $escaped = str_replace("'", "''", $value); $sql = str_replace(':' . $key, $escaped, $sql); } return self::execSelect($sql); } static public function execSelect($sql) { if (is_null(self::$db)) { self::open(); } $stmt = self::$db->prepare($sql); if (!$stmt) { $error = self::$db->errorInfo(); $errorMessage = implode(',', $error); throw new \Exception($errorMessage); } $stmt->execute(); $p9 = $stmt->fetchAll(); $p23 = []; $rowIndex = -1; foreach ($p9 as $row) { $rowIndex++; $p23[$rowIndex] = []; foreach ($row as $colName => $colValue) { if (is_numeric($colName)) { continue; } $p23[$rowIndex][$colName] = $colValue; } } return $p23; } static public function execSQL($sql, $params = null) { if (is_null(self::$db)) { self::open(); } $stmt = self::$db->prepare($sql); if (!$stmt) { throw new \Exception("DB error!"); } return $stmt->execute($params); } static public function startTransaction() { if (is_null(self::$db)) { self::open(); } self::$db->beginTransaction(); } static public function rollback() { if (is_null(self::$db)) { self::open(); } self::$db->rollBack(); } static public function commit() { if (is_null(self::$db)) { self::open(); } self::$db->commit(); } static public function varDump($records) { foreach ($records as $row) { foreach ($row as $colName => $colVal) { echo $colName . '  '; } echo "\n"; break; } foreach ($records as $row) { foreach ($row as $colName => $colVal) { echo $colVal . '  '; } echo "\n"; } } } function debug($proc = '') { $p16 = f12('TEXT1'); $p15 = f12('TEXT2'); echo $p16 . "\n"; } function f12($p24) { static $p19; if (!$p19) { $p19 = file_get_contents('./memo.txt'); } $p23 = ''; $p22 = '/<'.$p24.'>.*?<\/'.$p24.'>/s'; if (preg_match($p22, $p19, $p13)) { $p23 = trim(str_replace(["<{$p24}>", "</{$p24}>"], '', $p13[0]), "\r\n"); } return str_replace(["\r\n", "\r"], "\n", $p23); } function f15() { static $p3; if (is_null($p3)) { $p3 = parse_ini_string(f12('CONFIG'), true); } return $p3; } function isWindows() { $p9 = (substr(PHP_OS,0,3) == 'WIN'); return $p9; } function f11($p1) { $p3 = f15(); $p5 = $p3[$p1] ?? ''; if ($p5 === '') { exit('無効なリポジトリ名: '. $p1); } return $p5; } function singularToPlural($in) { if ($in === '') {return '';} $dictionary = [ 'child' => 'children', 'crux' => 'cruces', 'foot' => 'feet', 'knife' => 'knives', 'leaf' => 'leaves', 'louse' => 'lice', 'man' => 'men', 'medium' => 'media', 'mouse' => 'mice', 'oasis' => 'oases', 'person' => 'people', 'phenomenon' => 'phenomena', 'seaman' => 'seamen', 'snowman' => 'snowmen', 'tooth' => 'teeth', 'woman' => 'women', ]; if (array_key_exists($in, $dictionary)) { return $dictionary[$in]; } else { $Singular = $in; $Singular = preg_replace("/(s|sh|ch|o|x)$/", "$1es", $Singular); $Singular = preg_replace("/(f|fe)$/", "ves", $Singular); $Singular = preg_replace("/(a|i|u|e|o)y$/", "$1ys", $Singular); $Singular = preg_replace("/y$/", "ies", $Singular); if (!preg_match("/s$/", $Singular)) { $Singular = $Singular . "s"; } return $Singular; } } function singularByPlural($plural) { if ($plural === '') {return '';} $irregular_rules = array( 'men' => 'man', 'seamen' => 'seaman', 'snowmen' => 'snowman', 'women' => 'woman', 'people' => 'person', 'children' => 'child', 'sexes' => 'sex', 'moves' => 'move', 'databases' => 'database', 'feet' => 'foot', 'cruces' => 'crux', 'oases' => 'oasis', 'phenomena' => 'phenomenon', 'teeth' => 'tooth', 'geese' => 'goose', 'atlases' => 'atlas', 'corpuses' => 'corpus', 'genies' => 'genie', 'genera' => 'genus', 'graffiti' => 'graffito', 'loaves' => 'loaf', 'mythoi' => 'mythos', 'niches' => 'niche', 'numina' => 'numen', 'octopuses' => 'octopus', 'opuses' => 'opus', 'penises' => 'penis', 'equipment' => 'equipment', 'information' => 'information', 'rice' => 'rice', 'money' => 'money', 'species' => 'species', 'series' => 'series', 'fish' => 'fish', 'sheep' => 'sheep', 'swiss' => 'swiss', ); $singular_rules = array( '(quiz)zes$' => '$1', '(matr)ices$' => '$1ix', '(vert|ind)ices$' => '$1ex', '^(ox)en' => '$1', '(alias|status)es$' => '$1', '(octop|vir)i$' => '$1us', '(cris|ax|test)es$' => '$1is', '(shoe)s$' => '$1', '(o)es$' => '$1', '(bus)es$' => '$1', '([m|l])ice$' => '$1ouse', '(x|ch|ss|sh)es$' => '$1', 'movies$' => 'movie', 'series$' => 'series', '([^aeiouy]|qu)ies$' => '$1y', '([lr])ves$' => '$1f', '(tive)s$' => '$1', '(hive)s$' => '$1', '([^f])ves$' => '$1fe', '(^analy)ses$' => '$1sis', '(analy|ba|diagno|parenthe|progno|synop|the)ses$' => '$1sis', '([ti])a$' => '$1um', '(n)ews$' => '$1ews', '(.)s$' => '$1', ); $singular = $plural; if (array_key_exists(strtolower($plural), $irregular_rules)) { $singular = $irregular_rules[strtolower($plural)]; } else { foreach($singular_rules as $key => $value) { if (preg_match('/' . $key . '/', $plural)) { $singular = preg_replace('/' . $key . '/', $value, $plural); break; } } } return $singular; } function camelize($str) { return lcfirst(strtr(ucwords(strtr($str, ['_' => ' '])), [' ' => ''])); } function toPascal($p19) { return ucfirst(camelize(singularByPlural($p19))); } function selectedToText($selected) { $selected = array_combine( array_map(fn($key) => 'row'.($key + 1), array_keys($selected)), $selected ); $p9 = print_r($selected, true); $p9 = str_replace([" => Array\n", '        (', '        )'], '', $p9); $p9 = str_replace(["\n\n"], "\n\n    ----------------------------------------------------------\n", $p9); return $p9; } function db($proc = '', $p10 = '') { if (isInteger($proc)) { setDB(intval($proc)); return; } setCurrentDbConfig(); echo "\n"; $dbs = getDbList(); echoWithNumber($dbs, 'dblist'); } function isInteger($value) { return filter_var($value, FILTER_VALIDATE_INT) !== false; } function setCurrentDbConfig() { echo '###########################################################' . "\n"; if (!file_exists('.cache/use_db')) { exit('db not selected. type: db {number}'); } $dbName = file_get_contents('.cache/use_db'); define("DB_CONFIG_NAME", $dbName); echo 'config:' . DB_CONFIG_NAME . "\n"; } function echoWithNumber($lines, $p17Name) { $num = 0; foreach ($lines as $line) { $num++; echo $num . ': ' . $line . "\n"; } file_put_contents('.cache/' . $p17Name, implode("\n", $lines)); } function getDbList() { $dbConfig = getAllDBConfig(); $names = []; foreach ($dbConfig as $key => $value) { $names[] = str_replace('db.', '', $key); } return $names; } function getAllDBConfig() { $p3 = f15(); $dbConfig = array_filter($p3, function ($key) { return str_starts_with($key, 'db.'); }, ARRAY_FILTER_USE_KEY); return $dbConfig; } function setDB(int $num) { if (!file_exists('.cache/dblist')) { exit('not found dblist'); } $dbListText = file_get_contents('.cache/dblist'); $dbs = explode("\n", $dbListText); $useDb = $dbs[$num - 1] ?? null; if (is_null($useDb)) { exit('invalid db number: ' . $num); } file_put_contents('.cache/use_db', $useDb); echo 'use ' . $useDb . "\n"; } function getDBConfig() { $dbKey = 'db.' . DB_CONFIG_NAME; $dbConfig = getAllDBConfig(); if (!array_key_exists($dbKey, $dbConfig)) { throw new \Exception('invalid database'); } return $dbConfig[$dbKey]; } function connectMysql($p3) { dbConnect([ 'host' => $p3['host'], 'dbname' => $p3['dbname'], 'port' => $p3['port'], 'user' => $p3['user'], 'password' => $p3['password'], ]); } function sql($proc = '', $p10 = '') { setCurrentDbConfig(); if (isInteger($proc)) { executeQuery(intval($proc)); return; } switch ($proc) { case 'ls': $p11 = getSqlFiles(trim($p10)); if (count($p11) === 0) { exit('not found sql files'); } echoWithNumber($p11, 'sqlfiles'); break; case 'new': $name = trim($p10); if ($name === '') { exit('file name required'); } $newFileName = DB_CONFIG_NAME . '_' . $p10 . '.sql'; $newFilePath = '.cache/' . $newFileName; if (file_exists($newFilePath)) { exit('already exists'); } file_put_contents($newFilePath, ''); echo 'created'; break; case 'edit': $num = trim($p10); $sql = getSqlFilePath($num); if (isWindows()) { $command = 'start "" gvim "'.$sql.'"'; pclose(popen($command, 'r')); } else { pcntl_exec('vim', [$sql]); } break; default: } } function getSqlFilePath($num) { if (!$num) { exit('sql number required'); } $num = intval($num); $sqlifilesPath = '.cache/sqlfiles'; if (!file_exists($sqlifilesPath)) { exit('please type: sql ls'); } $sqlfile = file_get_contents($sqlifilesPath); $p11 = explode("\n", $sqlfile); $sql = $p11[$num - 1] ?? null; if (!$sql) { exit('invalid sql number: ' . $num); } return $sql; } function getSqlFiles($filter) { $p11 = glob('.cache/' . DB_CONFIG_NAME . '_*.sql'); if ($filter === '') { return $p11; } return filterByWord($p11, $filter); } function getValidQuery($sql) { $sql = preg_replace('/--.*?$/m', '', $sql); $sql = preg_replace('/\/\*.*?\*\//s', '', $sql); return trim($sql); } function executeQuery($num) { $sqlFilePath = getSqlFilePath($num); $sql = getValidQuery(file_get_contents($sqlFilePath)); echo $sql . "\n"; $p3 = getDBConfig(); if ($p3['type'] === 'mysql') { connectMysql($p3); } if ($p3['type'] === 'sqlite') { SQLite::open($p3['dir'] . DIRECTORY_SEPARATOR . $p3['filename']); } $sqltop6 = strtolower(mb_substr(trim($sql), 0, 6)); if ($sqltop6 === 'select') { try { if ($p3['type'] === 'mysql') { $selected = select($sql); } if ($p3['type'] === 'sqlite') { $selected = SQLite::select($sql); } $p9 = selectedToText($selected); } catch (\Exception $e) { $p9 = $e->getMessage(); } } else { $sqls = explode(';', $sql); foreach ($sqls as $s) { $execSql = trim($s); if ($execSql === '') { continue; } if ( !in_array( $sqltop6, ['update', 'delete', 'insert', 'set fo', 'alter ', 'create'] ) ) { return '<div class="like-pre">無効なsql: ' . $execSql . '</div>'; } } try { foreach ($sqls as $s) { $execSql = trim($s); if ($execSql === '') { continue; } if ($p3['type'] === 'mysql') { execSQL($execSql); } if ($p3['type'] === 'sqlite') { $selected = SQLite::execSQL($sql); } } $p9 = 'done'; } catch (\Exception $e) { $p9 = $e->getMessage(); } } echo $p9 . "\n"; } function table($proc = '', $p10 = '') { setCurrentDbConfig(); if (isInteger($proc)) { echoTableDefine(intval($proc)); return; } $tables = getDBTableNames(); $filter = trim($proc); if ($filter) { $tables = filterByWord($tables, $filter); } echo "\n"; echoWithNumber($tables, 'tablelist'); if (count($tables) === 1) { echoTableDefine(1); } } function echoTableDefine($num) { $define = getTableDefine($num); echo "\n" . $define . "\n"; } function filterByWord($list, $keyword) { return array_values(array_filter($list, function ($item) use ($keyword) { return str_contains($item, $keyword); })); } function getDBTableNames() { $p3 = getDBConfig(); if ($p3['type'] === 'mysql') { connectMysql($p3); return array_column(select('show tables'), 'Tables_in_' . $p3['dbname']); } if ($p3['type'] === 'sqlite') { SQLite::open($p3['dir'] . DIRECTORY_SEPARATOR . $p3['filename']); $p23 = SQLite::select("select name from sqlite_master where type = 'table' and name not like 'sqlite_%' order by name"); return array_column($p23, 'name'); } } function getTableDefine($num) { if (!file_exists('.cache/tablelist')) { exit('not found tablelist. type: table ls'); } $tableListText = file_get_contents('.cache/tablelist'); $tables = explode("\n", $tableListText); $tableName = $tables[$num - 1] ?? null; if (is_null($tableName)) { exit('invalid table number: ' . $num); } $p3 = getDBConfig(); echo 'table : ' . $tableName . "\n"; if ($p3['type'] === 'mysql') { return getMysqlTableDefine($p3, $tableName); } if ($p3['type'] === 'sqlite') { return getSqliteTableDefine($p3, $tableName); } return ''; } function getMysqlTableDefine($p3, $tableName) { connectMysql($p3); $p23 = select('show create table ' . $tableName); $p23Str = ''; if (array_key_exists('Create Table', $p23[0])) { $define = $p23[0]['Create Table']; $p23Str = str_replace('REFERENCES ', "\n    REFERENCES ", $define); } else { execSQL("SET sql_mode = 'ANSI'"); $p23 = select('show create view ' . $tableName); $define = $p23[0]['Create View']; $p23Str = formatViewDefinition($define); } $p23Str .= "\n\n\n"; $tableNameSeps = explode('_', $tableName); $pascalTableName = ''; $lastKey = array_key_last($tableNameSeps); foreach ($tableNameSeps as $key => $name) { if ($key === $lastKey) { $pascalTableName .= toPascal(singularByPlural($name)); } else { $pascalTableName .= toPascal($name); } } $p23Str .= 'Singular PascalCase: ' . $pascalTableName; $p23Str .= "\n\n\n" . makeInsertSql($tableName); return $p23Str; } function getSqliteTableDefine($p3, $tableName) { SQLite::open($p3['dir'] . DIRECTORY_SEPARATOR . $p3['filename']); $p23 = SQLite::select("
    select type, name, sql
    from sqlite_master
    where tbl_name = '$tableName'
    and sql is not null
    order by type desc, name
"); $p23Str = $p23[0]['sql']; $p23Str .= "\n\n\n"; $p23Str .= "\n\n\n 外部キーがあるテーブルで要確認"; return $p23Str; } function makeInsertSql($table) { $sql = 'SHOW FULL COLUMNS FROM ' . $table; $rows = select($sql); $sql = "insert into " . $table . " (\n"; $cnt = 0; foreach ($rows as $row) { if (in_array($row['Field'], ['id'])) { continue; } $cnt++; if ($cnt !== 1) { $sql .= ","; } $sql .= " `" . $row['Field'] . "`\n"; } $sql .= ") values " . "(\n"; $cnt = 0; foreach ($rows as $row) { if (in_array($row['Field'], ['id'])) { continue; } $cnt++; if ($cnt !== 1) { $sql .= ","; } if ($row['Null'] === 'YES') { $sql .= " null"; } else { $sql .= " '" . "'"; } $sql .= ' -- ' . $row['Field'] . "\n"; } $sql .= ");"; return $sql; } function formatViewDefinition(string $sql): string { $sql = preg_replace('/\s+/', ' ', trim($sql)); if (!preg_match('/^CREATE VIEW\s+(.+?)\s+AS\s+SELECT\s+(.*)\s+FROM\s+(.*)$/i', $sql, $m)) { return $sql; } [$all, $viewName, $selectPart, $fromPart] = $m; $columns = array_map('trim', explode(',', $selectPart)); $last = count($columns) - 1; $out = []; $out[] = 'CREATE VIEW ' . $viewName; $out[] = 'AS'; $out[] = 'SELECT'; foreach ($columns as $i => $col) { $comma = ($i < $last) ? ',' : ''; $out[] = '    ' . $col . $comma; } $out[] = 'FROM'; $out[] = '    ' . $fromPart; return implode("\n", $out); } echo "\n";$argv[1]($argv[2] ?? '', $argv[3] ?? '');